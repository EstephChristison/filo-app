# FILO Frontend Environment Variables
# Copy this file to .env and fill in your values
# For Vercel: add these in Settings → Environment Variables

# Backend API URL (your Railway deployment)
VITE_API_URL=https://api.myfilocrm.com/api

# Stripe publishable key (for checkout/payment elements)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# App URL (used for OAuth redirects, sharing links)
VITE_APP_URL=https://app.myfilocrm.com
